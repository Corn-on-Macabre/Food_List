VITE_GOOGLE_MAPS_API_KEY=
# Google Maps API key must have "Places API (New)" enabled in GCP console.
# The same key above is used for Places; set a separate key here only if desired.
# VITE_GOOGLE_MAPS_PLACES_API_KEY=
# Set a strong password for the /admin curator dashboard
VITE_ADMIN_PASSWORD=

# Supabase (Epic 7+) — leave blank to use static restaurants.json fallback
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
