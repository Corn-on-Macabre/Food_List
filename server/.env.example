# Copy to server/.env and fill in — server/.env is gitignored and never committed.
# Claude reads this locally for deploys/scripts; the values are placed into the
# VPS docker-compose environment over SSH (never through chat, never into git).

# Supabase project URL (same as VITE_SUPABASE_URL in the root .env)
SUPABASE_URL=https://mmhtpwxnygitjolkrpyc.supabase.co

# Supabase service_role secret — full read/write, bypasses RLS. Server-side only.
SUPABASE_SERVICE_KEY=

# Optional: Google Places key for enrichment scripts run from this machine
# GOOGLE_API_KEY=
